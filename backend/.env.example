# Email Configuration
# Pentru development local, puteți folosi Mailtrap (https://mailtrap.io/) - gratuit
# sau MailPit (http://mailpit.io/) - instalabil local
# sau chiar localhost:1025 pentru MailCatcher local

# Email provider settings (Mailtrap sau Custom SMTP)
EMAIL_HOST=smtp.mailtrap.io
EMAIL_PORT=2525
EMAIL_SECURE=false
EMAIL_USER=your_mailtrap_user@example.com
EMAIL_PASS=your_mailtrap_password
EMAIL_FROM=noreply@coliving-app.com

# Opțional: Gmail cu App Password
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_SECURE=false
# EMAIL_USER=your-email@gmail.com
# EMAIL_PASS=your-app-specific-password

# Pentru testare locală cu MailPit (recommended):
# EMAIL_HOST=localhost
# EMAIL_PORT=1025
# EMAIL_SECURE=false
